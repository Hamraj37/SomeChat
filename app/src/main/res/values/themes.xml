<resources>
    <!-- Base application theme. -->
    <style name="Theme.SomeChat" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/whatsapp_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/whatsapp_green_dark</item>
        <item name="colorOnPrimaryContainer">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/whatsapp_light_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/whatsapp_green_dark</item>
        <item name="colorOnSecondaryContainer">@color/white</item>
        <item name="android:textColorHighlight">@color/text_selection_highlight</item>
        <item name="colorAccent">@color/whatsapp_light_green</item>
        <item name="colorControlActivated">@color/whatsapp_light_green</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.SomeChat.NoActionBar" parent="Theme.SomeChat">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.SomeChat.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.SomeChat.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="CircleAppearance">
        <item name="cornerSize">50%</item>
    </style>

    <style name="FabShapeAppearance">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedTopRightBottomRight">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomRight">12dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>
</resources>